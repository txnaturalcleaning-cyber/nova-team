// api/voice-twiml-fallback.js
// Called when browser doesn't answer AND AI is OFF (manager mode)
// Plays a simple message — no AI involved

export default function handler(req, res) {
  const { To } = req.body || {};
  const fbBase  = 'https://nova-launch-system-default-rtdb.firebaseio.com';

  res.setHeader('Content-Type', 'text/xml');
  res.send(`<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say voice="Polly.Joanna" language="en-US">
    Thank you for calling. Our team is currently busy. Please leave a message after the tone, or call back shortly.
  </Say>
  <Record maxLength="60" transcribe="false" action="/api/ai-voicemail"/>
</Response>`);
}
