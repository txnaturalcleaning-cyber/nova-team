// api/voice-inbound.js
// Set this URL in Twilio Phone Number → Voice Configuration → A call comes in

export default function handler(req, res) {
  try {
    const From     = req.body?.From || '';
    const identity = process.env.TWILIO_CLIENT_IDENTITY || 'nova_user';
    const baseUrl  = 'https://nova-team-omega.vercel.app';

    console.log('Inbound call from:', From, '→ identity:', identity);

    // Build TwiML manually — no package dependency, can't crash
    const xml = `<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Dial callerId="${From}"
        record="record-from-answer"
        recordingStatusCallback="${baseUrl}/api/recording-webhook"
        recordingStatusCallbackMethod="POST"
        timeout="30">
    <Client>${identity}</Client>
  </Dial>
</Response>`;

    res.setHeader('Content-Type', 'text/xml');
    return res.send(xml);

  } catch(e) {
    console.error('voice-inbound error:', e.message);
    // Always return valid TwiML — never let Twilio get empty response
    res.setHeader('Content-Type', 'text/xml');
    return res.send(`<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say voice="alice">We are unable to take your call right now. Please try again later.</Say>
</Response>`);
  }
}
